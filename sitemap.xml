---
permalink: "/sitemap.xml"
layout: 
---

<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xhtml="http://www.w3.org/1999/xhtml" xmlns:image="http://www.google.com/schemas/sitemap-image/1.1" xsi:schemaLocation="http://www.sitemaps.org/schemas/sitemap/0.9 http://www.sitemaps.org/schemas/sitemap/0.9/sitemap.xsd http://www.w3.org/1999/xhtml http://www.w3.org/2002/08/xhtml/xhtml1-strict.xsd">
  {% for post in site.posts %}
    {% if post.id contains "404" %}{% else %}
      {% if post.title %}
        <url>
          <loc>{{site.url}}{{ post.url }}</loc>
          {% if post.ref %}
            {% assign versions=site.posts | where:"ref", post.ref %}
            {% for version in versions %}
              <xhtml:link rel="alternate" hreflang="{{ version.lang }}" href="{{site.url}}{{ version.url }}" />
            {% endfor %}
          {% endif %}
          {% if post.banner_image %}
            {% if post.netlifycms %}
              {% assign post_img_url = post.banner_image | prepend: site.url %}
            {% else %}
              {% assign post_img_url = post.banner_image | prepend: "/images/posts/" | prepend: site.url %}
            {% endif %}
          <image:image>
            <image:loc>{{ post_img_url }}</image:loc>
            <image:title>{{ post.title | xml_escape }}</image:title>
          </image:image>
          {% endif %}
          <lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
          <changefreq>weekly</changefreq>
        </url>
      {% endif %}
    {% endif %}
  {% endfor %}
  {% for page in site.pages %}
    {% if page.id contains "404" %}{% else %}
      {% if page.title %}
      <url>
        <loc>{{site.url}}{{ page.url }}</loc>
        {% if page.ref %}
          {% assign versions=site.pages | where:"ref", page.ref %}
          {% for version in versions %}
            <xhtml:link rel="alternate" hreflang="{{ version.lang }}" href="{{site.url}}{{ version.url }}" />
          {% endfor %}
        {% endif %}
        {% if page.banner_image %}
          <image:image>
            <image:loc>{{ site.url }}/images/{{ page.banner_image }}</image:loc>
            <image:title>{{ page.title | xml_escape }}</image:title>
          </image:image>
        {% endif %}
        <changefreq>weekly</changefreq>
      </url>
      {% endif %}
    {% endif %}
  {% endfor %}
</urlset>