{
  "root": true,
  "env": {
    "browser": true,
    "node": true,
    "es2021": true
  },
  "globals": {
    "$": "readonly",
    "Data": "readonly",
    "coins": "readonly",
    "isLocalStorageAvailable": "readonly"
  },
  "ignorePatterns": [
    "js/jquery.js",
    "js/public/**"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "script"
  },
  "rules": {
    "comma-dangle": [
      "error",
      "never"
    ],
    "curly": [
      "error",
      "multi-line"
    ],
    "eqeqeq": "error",
    "no-alert": "warn",
    "no-console": "warn",
    "no-constant-condition": "warn",
    "no-debugger": "warn",
    "no-dupe-keys": "error",
    "no-empty": "error",
    "no-extra-semi": "error",
    "no-fallthrough": "error",
    "no-shadow": "error",
    "no-shadow-restricted-names": "error",
    "no-trailing-spaces": "error",
    "no-undef": "error",
    "no-unreachable": "error",
    "no-unused-vars": [
      "warn",
      {
        "args": "none",
        "ignoreRestSiblings": true
      }
    ],
    "quotes": [
      "error",
      "single",
      {
        "avoidEscape": true
      }
    ],
    "semi": [
      "error",
      "always"
    ]
  }
}
