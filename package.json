{
	"scripts": {
		"eslint": "eslint js/**/*.js",
		"test": "jest --coverage",
		"test:api-contracts": "node bin/check-api-contracts.js",
		"test:page-console": "node bin/check-page-console-errors.js",
		"test:watch": "jest --watch",
		"dev": "bundle exec ruby bin/jekyll-local.rb serve --incremental",
		"start": "bundle exec ruby bin/jekyll-local.rb serve --incremental",
		"partytown:sync": "node ./node_modules/@qwik.dev/partytown/bin/partytown.cjs copylib js/public/partytown --no-debug"
	},
	"devDependencies": {
		"eslint": "^8.57.1",
		"jest": "^29.7.0",
		"jest-environment-jsdom": "^29.7.0",
		"jquery": "^3.7.1"
	},
	"dependencies": {
		"@qwik.dev/partytown": "^0.11.2"
	},
	"jest": {
		"testEnvironment": "jsdom",
		"setupFilesAfterEnv": [
			"./tests/setup.js"
		],
		"collectCoverageFrom": [
			"js/*.js",
			"!js/jquery.js"
		],
		"coveragePathIgnorePatterns": [
			"/node_modules/",
			"/js/public/",
			"/_site/"
		],
		"testPathIgnorePatterns": [
			"/node_modules/",
			"/_site/"
		],
		"coverageThreshold": {
			"global": {
				"branches": 69,
				"functions": 89,
				"lines": 90,
				"statements": 88
			}
		}
	}
}
