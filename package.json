{
	"scripts": {
		"eslint": "eslint js/**/*.js",
		"test": "jest --coverage",
		"test:watch": "jest --watch",
		"dev": "bundle exec ruby bin/jekyll-local.rb serve --incremental",
		"start": "bundle exec ruby bin/jekyll-local.rb serve --incremental"
	},
	"devDependencies": {
		"eslint": "^8.57.1",
		"jest": "^29.7.0",
		"jest-environment-jsdom": "^29.7.0",
		"jquery": "^3.7.1"
	},
	"dependencies": {
		"@builder.io/partytown": "^0.8.0"
	},
	"jest": {
		"testEnvironment": "jsdom",
		"collectCoverageFrom": [
			"js/*.js",
			"!js/jquery.js"
		],
		"coveragePathIgnorePatterns": [
			"/node_modules/",
			"/js/public/",
			"/_site/"
		],
		"testPathIgnorePatterns": [
			"/node_modules/",
			"/_site/"
		]
	}
}
